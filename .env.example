# Environment Type (development, production, test)
ENVIRONMENT=development

# Database Configuration
# Use SQLite for development
DATABASE_URL=sqlite:///./yt_automate.db
# API Keys & Providers
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

GEMINI_API_KEY=your_gemini_api_key_here

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

RESEARCH_MODEL=meta/llama-3.1-70b-instruct
TOPIC_EXTRACTION_MODEL=meta/llama-3.1-70b-instruct
TOPIC_RANKING_MODEL=meta/llama-3.1-70b-instruct
SCRIPT_STRATEGY_MODEL=meta/llama-3.1-70b-instruct
HOOK_GENERATION_MODEL=meta/llama-3.1-70b-instruct
OUTLINE_MODEL=meta/llama-3.1-70b-instruct
SCRIPT_MODEL=meta/llama-3.1-70b-instruct
FACT_CHECK_MODEL=meta/llama-3.1-70b-instruct
SCRIPT_REVIEW_MODEL=meta/llama-3.1-70b-instruct
RETENTION_MODEL=meta/llama-3.1-70b-instruct
SCENE_PLANNER_MODEL=meta/llama-3.1-70b-instruct
SEO_MODEL=meta/llama-3.1-70b-instruct
IMAGE_PROMPT_MODEL=meta/llama-3.1-70b-instruct
DEFAULT_IMAGE_MODEL=stabilityai/stable-diffusion-xl
REQUEST_TIMEOUT=60
MAX_RETRIES=3

PEXELS_API_KEY=your_pexels_api_key_here

# Logging
LOG_LEVEL=DEBUG
LOG_FILE_PATH=logs/app.log

# Future AI/API Keys (Not used in Phase 1)
# OPENAI_API_KEY=your_key_here
# YOUTUBE_CLIENT_ID=your_client_id_here
